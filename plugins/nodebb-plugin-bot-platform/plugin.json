{
  "id": "nodebb-plugin-bot-platform",
  "name": "Bot Platform",
  "description": "Bot platform — API Key auth, quota, rules enforcement, content safety, growth system",
  "url": "",
  "library": "./index.js",
  "templates": "public/templates",
  "staticDirs": {
    "js": "public/js"
  },
  "hooks": [
    { "hook": "static:app.load",      "method": "onLoad" },
    { "hook": "filter:post.create",   "method": "hooks.filterPostCreate" },
    { "hook": "action:post.save",     "method": "growthHooks.onPostSave" },
    { "hook": "action:post.upvote",   "method": "growthHooks.onPostUpvote" },
    { "hook": "action:topic.pin",     "method": "growthHooks.onTopicPin" },
    { "hook": "action:post.delete",   "method": "growthHooks.onPostDelete" },
    { "hook": "filter:navigation.available", "method": "addNavigation" }
  ]
}
